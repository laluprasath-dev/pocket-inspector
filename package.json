{
  "name": "pocket-inspector-backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "node scripts/patch-prisma-client.js && nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "lsof -ti:3000 | xargs kill -9 2>/dev/null; nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:tsx": "tsx src/main.ts",
    "start:prod": "node dist/src/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "DATABASE_URL=postgresql://admin@localhost:5432/pocket_inspector_test JWT_SECRET=test-jwt-secret-at-least-32-chars-long-for-tests!! JWT_REFRESH_SECRET=test-refresh-secret-at-least-32-chars-long-for-tests GCS_PROJECT_ID=test-project GCS_BUCKET_NAME=test-bucket FCM_PROJECT_ID=test-fcm-project NODE_OPTIONS=--experimental-vm-modules jest --config ./test/jest-e2e.json --runInBand",
    "test:prod": "newman run postman/Pocket-Inspector.postman_collection.json --environment postman/Pocket-Inspector.postman_environment.json --env-var baseUrl=https://pocket-inspector-api-34292529156.europe-west2.run.app --env-var adminEmail=admin@example.com --env-var adminPassword=Admin1234! --env-var inspectorEmail=inspector@example.com --env-var inspectorPassword=Inspector1234! --timeout-request 30000",
    "user:create": "tsx scripts/create-user.ts",
    "test:image-upload": "tsx scripts/test-image-upload.ts",
    "gcs:set-cors": "GOOGLE_APPLICATION_CREDENTIALS=secrets/pocket-inspector-production-firebase-adminsdk-fbsvc-dbda2bd3b2.json tsx scripts/set-gcs-cors.ts",
    "gcs:set-thumb-iam": "tsx scripts/set-thumb-iam.ts",
    "backfill:thumbnails": "tsx scripts/backfill-thumbnails.ts",
    "postprisma:generate": "tsx scripts/patch-prisma-client.ts",
    "db:seed": "tsx prisma/seed.ts",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate && node scripts/patch-prisma-client.js",
    "db:studio": "prisma studio"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/helmet": "^13.0.2",
    "@fastify/static": "^9.0.0",
    "@google-cloud/storage": "^7.19.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-fastify": "^11.1.15",
    "@nestjs/swagger": "^11.2.6",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "archiver": "^7.0.1",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "firebase-admin": "^13.7.0",
    "joi": "^18.0.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pg": "^8.20.0",
    "prisma": "7.4.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@swc/core": "^1.15.18",
    "@swc/jest": "^0.2.39",
    "@types/archiver": "^7.0.0",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/pg": "^8.18.0",
    "@types/sharp": "^0.31.1",
    "@types/supertest": "^6.0.2",
    "dotenv": "^17.3.1",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "fastify": "^5.7.4",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "prisma": "7.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
