# ============================================================
# Pocket Inspector Backend — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ============================================================

# ── Server ────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Database ──────────────────────────────────────────────
# Local:      postgresql://USER:PASSWORD@localhost:5432/pocket_inspector
# Cloud SQL:  postgresql://USER:PASSWORD@/DB_NAME?host=/cloudsql/PROJECT:REGION:INSTANCE
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/pocket_inspector

# ── Authentication ─────────────────────────────────────────
# Generate: openssl rand -base64 32
JWT_SECRET=REPLACE_WITH_A_STRONG_SECRET_AT_LEAST_32_CHARS
JWT_EXPIRES_IN=15m

JWT_REFRESH_SECRET=REPLACE_WITH_ANOTHER_STRONG_SECRET_AT_LEAST_32_CHARS
JWT_REFRESH_EXPIRES_IN=7d

# ── Google Cloud Storage ───────────────────────────────────
GCS_PROJECT_ID=your-gcp-project-id
GCS_BUCKET_NAME=your-private-gcs-bucket-name

# Signed URL lifetime in seconds (default: 900 = 15 min)
GCS_SIGNED_URL_EXPIRY_SECONDS=900

# Path to the GCS service account key JSON file.
# LOCAL DEV ONLY — in production use the Cloud Run service account (ADC).
GOOGLE_APPLICATION_CREDENTIALS=secrets/your-gcs-service-account.json

# Service account email used to sign GCS URLs via IAM signBlob API.
# PRODUCTION: set to pocket-inspector-storage@<project>.iam.gserviceaccount.com
# LOCAL DEV: leave empty (keyFilename above is used instead).
GCS_SERVICE_ACCOUNT_EMAIL=

# ── Firebase Cloud Messaging ────────────────────────────────
FCM_PROJECT_ID=your-firebase-project-id

# Full contents of the Firebase Admin SDK service account JSON as a
# single-line string. Used in production (Cloud Run / CI).
# Local dev: leave empty and use GOOGLE_APPLICATION_CREDENTIALS instead.
# Generate: cat secrets/firebase-key.json | python3 -c "import sys,json; print(json.dumps(json.load(sys.stdin)))"
FIREBASE_SERVICE_ACCOUNT_KEY=
