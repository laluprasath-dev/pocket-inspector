# ============================================================
# Pocket Inspector Backend — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ============================================================

# ── Server ────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Database ──────────────────────────────────────────────
# PostgreSQL connection string (used by Prisma at runtime and in prisma.config.ts)
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/pocket_inspector

# ── Authentication ─────────────────────────────────────────
# Must be at least 32 characters. Generate with: openssl rand -base64 32
JWT_SECRET=REPLACE_WITH_A_STRONG_SECRET_AT_LEAST_32_CHARS
JWT_EXPIRES_IN=15m

# Separate secret for refresh tokens
JWT_REFRESH_SECRET=REPLACE_WITH_ANOTHER_STRONG_SECRET_AT_LEAST_32_CHARS
JWT_REFRESH_EXPIRES_IN=7d

# ── Google Cloud Storage ───────────────────────────────────
# GCS project and bucket (europe-west2 / London region per spec)
GCS_PROJECT_ID=your-gcp-project-id
GCS_BUCKET_NAME=your-private-gcs-bucket-name

# Signed URL expiry in seconds (default: 900 = 15 minutes)
GCS_SIGNED_URL_EXPIRY_SECONDS=900

# Path to the GCP service account key JSON file (for local dev).
# In production, use Workload Identity or inject the JSON via env instead.
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# ── Firebase Cloud Messaging ────────────────────────────────
FCM_PROJECT_ID=your-firebase-project-id

# Stringified JSON of the Firebase service account key (for production env injection).
# For local dev you can use GOOGLE_APPLICATION_CREDENTIALS instead.
FIREBASE_SERVICE_ACCOUNT_KEY=
