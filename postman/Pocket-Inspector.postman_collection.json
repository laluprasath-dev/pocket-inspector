{
  "info": {
    "name": "Pocket Inspector API",
    "description": "Complete API collection for Pocket Inspector backend.\n\n## Quick Start\n1. Import this collection\n2. Import `Pocket-Inspector.postman_environment.json` alongside it\n3. Select the **Pocket Inspector — Local** environment\n4. Run **Auth → Login as Admin** — tokens are saved automatically\n5. All other requests will use the saved token\n\n## Auto-token Flow\nThe **Login as Admin** and **Login as Inspector** requests include a test script that automatically saves `accessToken`, `refreshToken`, `adminId`, and `inspectorId` to the active environment.\n\nAll requests use `{{accessToken}}` in the Authorization header via the collection-level auth setting.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "pocket-inspector-v1"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    { "key": "baseUrl",       "value": "http://localhost:3000", "type": "string" },
    { "key": "accessToken",   "value": "", "type": "string" },
    { "key": "refreshToken",  "value": "", "type": "string" },
    { "key": "adminId",       "value": "", "type": "string" },
    { "key": "inspectorId",   "value": "", "type": "string" },
    { "key": "siteId",        "value": "", "type": "string" },
    { "key": "buildingId",    "value": "", "type": "string" },
    { "key": "floorId",       "value": "", "type": "string" },
    { "key": "doorId",        "value": "", "type": "string" },
    { "key": "inspectionId",  "value": "", "type": "string" },
    { "key": "exportJobId",   "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "🔑 Auth",
      "item": [
        {
          "name": "Login as Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data) {",
                  "    pm.collectionVariables.set('accessToken',  json.data.accessToken);",
                  "    pm.collectionVariables.set('refreshToken', json.data.refreshToken);",
                  "    pm.test('Login successful — tokens saved', () => {",
                  "        pm.expect(json.data.accessToken).to.be.a('string');",
                  "    });",
                  "} else {",
                  "    pm.test('Login FAILED — check email/password', () => { pm.expect(false).to.be.true; });",
                  "}",
                  "",
                  "// Also save adminId from /v1/auth/me",
                  "const meReq = {",
                  "    url: pm.collectionVariables.get('baseUrl') + '/v1/auth/me',",
                  "    method: 'GET',",
                  "    header: { Authorization: 'Bearer ' + json.data.accessToken }",
                  "};",
                  "pm.sendRequest(meReq, (err, res) => {",
                  "    if (!err && res.json().data) {",
                  "        pm.collectionVariables.set('adminId', res.json().data.id);",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"Admin1234!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "auth", "login"]
            },
            "description": "Authenticates as admin. Automatically saves `accessToken` and `refreshToken` to collection variables."
          }
        },
        {
          "name": "Login as Inspector",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data) {",
                  "    pm.collectionVariables.set('accessToken',  json.data.accessToken);",
                  "    pm.collectionVariables.set('refreshToken', json.data.refreshToken);",
                  "    pm.test('Inspector login successful', () => {",
                  "        pm.expect(json.data.accessToken).to.be.a('string');",
                  "    });",
                  "    const meReq = {",
                  "        url: pm.collectionVariables.get('baseUrl') + '/v1/auth/me',",
                  "        method: 'GET',",
                  "        header: { Authorization: 'Bearer ' + json.data.accessToken }",
                  "    };",
                  "    pm.sendRequest(meReq, (err, res) => {",
                  "        if (!err && res.json().data) {",
                  "            pm.collectionVariables.set('inspectorId', res.json().data.id);",
                  "        }",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"inspector@example.com\",\n  \"password\": \"Inspector1234!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "auth", "login"]
            },
            "description": "Authenticates as inspector. Saves tokens + inspectorId to collection variables."
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data) {",
                  "    pm.collectionVariables.set('accessToken',  json.data.accessToken);",
                  "    pm.collectionVariables.set('refreshToken', json.data.refreshToken);",
                  "    pm.test('Tokens refreshed', () => pm.response.to.have.status(200));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/auth/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "auth", "refresh"]
            },
            "description": "Exchange a refresh token for a new token pair. New tokens are saved automatically."
          }
        },
        {
          "name": "Get Current User (me)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/v1/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "auth", "me"]
            },
            "description": "Returns the authenticated user's profile. `passwordHash` is never included."
          }
        }
      ]
    },
