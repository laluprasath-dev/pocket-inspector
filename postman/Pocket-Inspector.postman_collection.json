          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"FRONT\",\n  \"contentType\": \"image/jpeg\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/doors/{{doorId}}/images/signed-upload",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "doors", "{{doorId}}", "images", "signed-upload"]
            },
            "description": "Returns a signed GCS URL (`uploadUrl`) and `objectPath`. Upload the image directly to `uploadUrl` using a PUT request with `Content-Type: image/jpeg`. Then call `Register Door Image`.\n\nRoles allowed: `INSPECTOR` (and `ADMIN`).\n\nImage roles: `FRONT` | `BACK` | `SIDE` | `LABEL` | `DAMAGE` | `OTHER`."
          }
        },
        {
          "name": "Register Door Image (after GCS upload)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"FRONT\",\n  \"objectPath\": \"{{imageObjectPath}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/doors/{{doorId}}/images/register",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "doors", "{{doorId}}", "images", "register"]
            },
            "description": "Call this after successfully uploading to GCS. Records the image in the database."
          }
        },
        {
          "name": "Request Door Certificate Upload (Admin only)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"contentType\": \"application/pdf\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/doors/{{doorId}}/certificate/signed-upload",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "doors", "{{doorId}}", "certificate", "signed-upload"]
            },
            "description": "Door must be in SUBMITTED status. Returns signed GCS URL for PDF upload."
          }
        },
        {
          "name": "Register Door Certificate (Admin only)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"objectPath\": \"orgs/ORG_ID/buildings/B_ID/floors/F_ID/doors/D_ID/certificate/cert.pdf\",\n  \"issuedAt\": \"2026-01-15T00:00:00.000Z\",\n  \"expiresAt\": \"2027-01-15T00:00:00.000Z\",\n  \"issuer\": \"Fire Safety Board\",\n  \"notes\": \"Passed annual inspection\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/doors/{{doorId}}/certificate/register",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "doors", "{{doorId}}", "certificate", "register"]
            },
            "description": "Records the certificate. Sets door status to CERTIFIED. Notifies assigned inspectors via FCM."
          }
        },
        {
          "name": "Get Door Certificate Download URL",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/v1/doors/{{doorId}}/certificate/signed-download",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "doors", "{{doorId}}", "certificate", "signed-download"]
            }
          }
        }
      ]
    },
    {
      "name": "🔍 Inspections",
      "item": [
        {
          "name": "List Inspections",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/v1/inspections",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "inspections"]
            },
            "description": "Admin sees all inspections in the org. Inspector only sees inspections they are assigned to."
          }
        },
        {
          "name": "Create Inspection (Admin only)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.id) {",
                  "    pm.collectionVariables.set('inspectionId', json.data.id);",
                  "    pm.test('Inspection created — inspectionId saved', () => pm.response.to.have.status(201));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"BUILDING\",\n  \"buildingId\": \"{{buildingId}}\",\n  \"notes\": \"Annual fire door compliance inspection Q1 2026\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/inspections",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "inspections"]
            },
            "description": "Creates an inspection and saves `inspectionId`.\n\nTypes: `BUILDING` (requires `buildingId`) | `SITE` (requires `siteId`)."
          }
        },
        {
          "name": "Get Inspection by ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/v1/inspections/{{inspectionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "inspections", "{{inspectionId}}"]
            }
          }
        },
        {
          "name": "Assign Inspector (Admin only)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"inspectorId\": \"{{inspectorId}}\",\n  \"adminNote\": \"Please complete this inspection by end of month\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/inspections/{{inspectionId}}/assignments",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "inspections", "{{inspectionId}}", "assignments"]
            },
            "description": "Assigns an inspector to an inspection. Inspector receives FCM push notification. Returns 400 if inspector is already assigned."
          }
        },
        {
          "name": "Respond to Assignment (Inspector)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"ACCEPTED\",\n  \"inspectorNote\": \"I will start tomorrow morning\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/inspections/{{inspectionId}}/assignments/respond",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "inspections", "{{inspectionId}}", "assignments", "respond"]
            },
            "description": "Inspector accepts or declines the assignment. Statuses: `ACCEPTED` | `DECLINED`. Returns 403 if already responded."
          }
        },
        {
          "name": "Archive Inspection (Admin only)",
          "request": {
            "method": "PATCH",
            "url": {
              "raw": "{{baseUrl}}/v1/inspections/{{inspectionId}}/archive",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "inspections", "{{inspectionId}}", "archive"]
            },
            "description": "Moves inspection to ARCHIVED status."
          }
        }
      ]
    },
    {
      "name": "📦 Exports",
      "item": [
        {
          "name": "Create Export Job (Admin only)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.id) {",
                  "    pm.collectionVariables.set('exportJobId', json.data.id);",
                  "    pm.test('Export job created — exportJobId saved', () => pm.response.to.have.status(201));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"targetType\": \"BUILDING\",\n  \"targetId\": \"{{buildingId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/exports",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "exports"]
            },
            "description": "Queues an async export job. The worker builds a ZIP of all images + certificates for the target.\n\nTarget types: `BUILDING` | `FLOOR` | `DOOR` | `SITE` | `INSPECTION`.\n\nPoll `GET /v1/exports/:id` until status is `DONE`, then call `Get Export Download URL`."
          }
        },
        {
          "name": "Get Export Job Status",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/v1/exports/{{exportJobId}}",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "exports", "{{exportJobId}}"]
            },
            "description": "Statuses: `QUEUED` → `RUNNING` → `DONE` | `FAILED`."
          }
        },
        {
          "name": "Get Export Download URL (when DONE)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/v1/exports/{{exportJobId}}/signed-download",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "exports", "{{exportJobId}}", "signed-download"]
            },
            "description": "Returns a short-lived signed GCS URL to download the ZIP. Returns 400 if job is not DONE yet."
          }
        }
      ]
    },
    {
      "name": "📱 Notifications",
      "item": [
        {
          "name": "Register Device Token (FCM)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"fcm-device-token-from-mobile-sdk\",\n  \"platform\": \"IOS\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/me/device-token",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "me", "device-token"]
            },
            "description": "Registers the mobile device's FCM token so the user can receive push notifications (assignment alerts, certificate issued, etc.).\n\nPlatforms: `IOS` | `ANDROID`.\n\nUpserts the token — safe to call on every app launch."
          }
        }
      ]
    },
    {
      "name": "❤️ Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            },
            "description": "Public endpoint. Returns app status and database connectivity + latency. No auth required."
          }
        }
      ]
    }
  ]
}
